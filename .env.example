PORT=5174

# Optional local hotel price inventory.
# Supports JSON array/object or CSV. Use HOTEL_DATA_FILES for multiple suppliers.
# This is the recommended path for China-wide supplier exports from Ctrip,
# Meituan, Fliggy, Tongcheng, channel-manager partners, or internal contracts.
# HOTEL_DATA_FILE=/absolute/path/to/hotel-prices.csv
# HOTEL_DATA_FILES=/absolute/path/ctrip.csv,/absolute/path/meituan.csv,/absolute/path/direct-contracts.json
# HOTEL_IMPORT_DIR=/absolute/path/to/uploaded-price-files

# Optional remote supplier exports. Use signed URLs or a protected internal endpoint
# that returns the same CSV/JSON schema as HOTEL_DATA_FILE.
# HOTEL_DATA_URL=https://example.com/hotel-prices.csv
# HOTEL_DATA_URLS=https://example.com/ctrip.csv,https://example.com/meituan.json
# HOTEL_DATA_URL_HEADERS={"Authorization":"Bearer your_token"}
# HOTEL_DATA_URL_TIMEOUT_MS=8000
# HOTEL_DATA_URL_MAX_BYTES=12582912

# Optional live hotel inventory provider.
# Register credentials with Amadeus for Developers, then uncomment:
# AMADEUS_CLIENT_ID=your_client_id
# AMADEUS_CLIENT_SECRET=your_client_secret
# AMADEUS_BASE_URL=https://test.api.amadeus.com
