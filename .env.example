PORT=5174

# Optional local hotel price inventory.
# Supports CSV, JSON, nested JSON, JSONL/NDJSON, and gzip-compressed
# .csv.gz/.json.gz/.jsonl.gz/.ndjson.gz files.
# Use HOTEL_DATA_FILES for multiple suppliers.
# This is the recommended path for China-wide supplier exports from Ctrip,
# Meituan, Fliggy, Tongcheng, channel-manager partners, or internal contracts.
# HOTEL_DATA_FILE=/absolute/path/to/hotel-prices.csv
# HOTEL_DATA_FILES=/absolute/path/ctrip.csv,/absolute/path/meituan.jsonl,/absolute/path/direct-contracts.json.gz
# HOTEL_IMPORT_DIR=/absolute/path/to/uploaded-price-files

# Optional remote supplier exports. Use signed URLs or a protected internal endpoint
# that returns the same CSV/JSON/JSONL schema as HOTEL_DATA_FILE.
# HOTEL_DATA_URL=https://example.com/hotel-prices.csv
# HOTEL_DATA_URLS=https://example.com/ctrip.csv,https://example.com/meituan.jsonl.gz
# HOTEL_DATA_MANIFEST_URL=https://example.com/hotel-suppliers.json
# HOTEL_DATA_MANIFEST_URLS=https://example.com/domestic-suppliers.json,https://example.com/direct-contracts.json
# HOTEL_DATA_MANIFEST_CONFIG={"sources":[{"name":"ctrip","url":"https://example.com/ctrip-prices.json","headers":{"Authorization":"Bearer ctrip_token"},"fieldMap":{"name":"hotel.title","city":"hotel.cityName","price":"rate.sale"}},{"name":"meituan","url":"https://example.com/meituan-prices.csv","headers":{"X-Api-Key":"meituan_key"}}]}
# HOTEL_DATA_URL_HEADERS={"Authorization":"Bearer your_token"}
# HOTEL_DATA_URL_TIMEOUT_MS=8000
# HOTEL_DATA_URL_MAX_BYTES=12582912
# HOTEL_DATA_CACHE_SECONDS=60

# Optional generic live hotel inventory API. The API should return the same
# CSV/JSON/JSONL shape as HOTEL_DATA_FILE. GET receives query parameters;
# POST receives the same query object as JSON.
# A single paginated supplier can also return total/coverageCities/pagination
# alongside hotels/items/results so the site can keep loading nationwide pages.
# Per-source auth supports client_credentials tokenUrl/clientIdEnv/clientSecretEnv
# and injects a cached Bearer token into live search requests.
# cityFanout can split province/nationwide searches into per-city supplier calls.
# destinationMap can translate internal city/province names into supplier IDs/codes.
# HOTEL_SUPPLIER_API_URL=https://example.com/api/hotel-search
# HOTEL_SUPPLIER_API_URLS=https://example.com/ctrip-live,https://example.com/meituan-live
# HOTEL_SUPPLIER_API_NAME=your_supplier_name
# HOTEL_SUPPLIER_API_NAMES=ctrip,meituan
# Use HOTEL_SUPPLIER_API_CONFIG when each supplier needs different method/headers.
# requestMap maps supplier request fields to internal query fields; requestDefaults
# adds fixed query/body fields such as locale, currency, or channel.
# requestMap can use derived page/pageSize fields for 1-based supplier pagination.
# requestMap can also use cityName/cityCode/cityId/provinceCode/destinationId/supplierDestination.*.
# responsePath points to nested hotel lists; paginationPath points to nested page info.
# fieldMap maps internal fields to supplier response dot paths or fallback path arrays.
# HOTEL_SUPPLIER_API_CONFIG=[{"name":"ctrip","url":"https://example.com/ctrip-live","method":"GET","auth":{"type":"client_credentials","tokenUrl":"https://example.com/oauth/token","clientIdEnv":"CTRIP_CLIENT_ID","clientSecretEnv":"CTRIP_CLIENT_SECRET","scope":"hotel.search"},"cityFanout":true,"cityFanoutConcurrency":4,"destinationMap":{"cities":{"南京":{"cityId":"320100","cityCode":"NKG"},"无锡":{"cityId":"320200","cityCode":"WUX"}}},"requestMap":{"cityId":"supplierDestination.cityId","cityName":"cityName","arrivalDate":"checkIn","departureDate":"checkOut","pageNo":"page","pageSize":"pageSize"},"requestDefaults":{"locale":"zh-CN","currency":"CNY"},"responsePath":"data.hotelList","paginationPath":"data.paging","fieldMap":{"id":"offerId","name":"hotel.title","province":"hotel.provinceName","city":"hotel.cityName","price":["rate.sale","price"],"checkIn":"stay.from","checkOut":"stay.to","bookingUrl":"rate.book"}},{"name":"meituan","url":"https://example.com/meituan-live","method":"POST","headers":{"X-Api-Key":"meituan_key"},"requestMap":{"destination.cityName":"city","stay.arrival":"checkIn","stay.departure":"checkOut","occupancy.adultCount":"adults","pagination.pageNo":"page","pagination.pageSize":"pageSize"}}]
# HOTEL_SUPPLIER_API_METHOD=GET
# HOTEL_SUPPLIER_API_HEADERS={"Authorization":"Bearer your_token"}
# HOTEL_SUPPLIER_API_TIMEOUT_MS=10000
# Optional short live API response cache in seconds. Default 0 disables it.
# HOTEL_SUPPLIER_API_CACHE_SECONDS=30
# HOTEL_SUPPLIER_API_CACHE_MAX_ENTRIES=1000
# Optional live API retries for temporary network/HTTP failures. Default count 0 disables it.
# HOTEL_SUPPLIER_API_RETRY_COUNT=2
# HOTEL_SUPPLIER_API_RETRY_DELAY_MS=300
# HOTEL_SUPPLIER_API_RETRY_STATUS_CODES=408,429,500,502,503,504
# Supplier coverage probes call each city with a small limit to verify nationwide availability.
# HOTEL_SUPPLIER_COVERAGE_PROBE_LIMIT=1
# HOTEL_SUPPLIER_COVERAGE_PROBE_CONCURRENCY=4
# Large destination maps can be stored outside HOTEL_SUPPLIER_API_CONFIG.
# Per-source options: destinationMapFile, destinationMapUrl, destinationMapHeaders.
# Example destination map JSON: [{"province":"江苏","city":"南京","cityId":"320100","cityCode":"NKG"}]

# Optional Amadeus live hotel inventory provider.
# Register credentials with Amadeus for Developers, then uncomment:
# AMADEUS_CLIENT_ID=your_client_id
# AMADEUS_CLIENT_SECRET=your_client_secret
# AMADEUS_BASE_URL=https://test.api.amadeus.com
